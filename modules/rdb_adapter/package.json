{
  "name": "@hyper-hyper-space/hhs3_rdb_adapter",
  "version": "0.1.0",
  "description": "Adapter that keeps a local relational database in sync with an rdb replica for HHSv3",
  "type": "module",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "node --import ../../register.mjs ./test/run_tests.ts",
    "bench": "node --import ../../register.mjs ./test/run_benchmark.ts",
    "debug": "node --inspect-brk --import ../../register.mjs ./test/run_tests.ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "author": "Santiago Bazerque",
  "license": "MIT",
  "dependencies": {
    "@hyper-hyper-space/hhs3_json": "^0.1.0",
    "@hyper-hyper-space/hhs3_crypto": "^0.1.0",
    "@hyper-hyper-space/hhs3_util": "^0.1.0",
    "@hyper-hyper-space/hhs3_mvt": "^0.1.0",
    "@hyper-hyper-space/hhs3_rdb": "^0.1.0",
    "@hyper-hyper-space/hhs3_replica": "^0.1.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "ts-node": "^10.9.2",
    "@types/node": "^22.2.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
