{
  "name": "@hyper-hyper-space/hhs3_rdb",
  "version": "0.1.0",
  "description": "Relational database Monotone View Types for HHSv3: RSchema, RTableGroup, RTable and RDb",
  "type": "module",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "node --import ../../register.mjs ./test/run_tests.ts",
    "test:parity": "node --import ../../register.mjs ./test/run_tests.ts DELTA_PARITY --profile extended",
    "debug": "node --inspect-brk --import ../../register.mjs ./test/run_tests.ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "author": "Santiago Bazerque",
  "license": "MIT",
  "dependencies": {
    "@hyper-hyper-space/hhs3_json": "^0.1.0",
    "@hyper-hyper-space/hhs3_crypto": "^0.1.0",
    "@hyper-hyper-space/hhs3_dag": "^0.1.0",
    "@hyper-hyper-space/hhs3_mvt": "^0.1.0",
    "@hyper-hyper-space/hhs3_mesh": "^0.1.0",
    "@hyper-hyper-space/hhs3_sync": "^0.1.0",
    "@hyper-hyper-space/hhs3_util": "^0.1.0"
  },
  "devDependencies": {
    "@hyper-hyper-space/hhs3_replica": "^0.1.0",
    "typescript": "6.0.3",
    "ts-node": "^10.9.2",
    "@types/node": "^22.2.0"
  }
}
